{
  "name": "glassbox-agent",
  "url": "https://github.com/agentic-trust-labs/glassbox-ai",
  "hook_attributes": {
    "url": "https://DEPLOY_URL/webhook",
    "active": true
  },
  "public": true,
  "default_permissions": {
    "issues": "write",
    "pull_requests": "write",
    "contents": "write",
    "metadata": "read"
  },
  "default_events": [
    "issues",
    "issue_comment",
    "installation"
  ],
  "description": "Autonomous coding agent that ships tested PRs from GitHub issues. Trust-scored multi-agent pipeline - every decision transparent."
}
